# ─────────────────────────────────────────────────────────────────────────
# AI-Powered Chatbot for Medical Diagnosis — Environment Configuration
# Copy this file to ".env" and fill in your own values. Never commit ".env".
# ─────────────────────────────────────────────────────────────────────────

# Google Gemini API key for the online AI engine.
# Leave blank to force the system to always use the built-in diagnostic engine.
GEMINI_API_KEY=

# PostgreSQL connection string for case memory + usage tracking.
# Get a free database at https://neon.tech — use the "Connection string" they
# provide (it already includes your username, password, host and database name).
# Example: postgresql://user:password@ep-xxxx.neon.tech/dbname
# Leave blank to run without persistence (caching/usage limits are disabled).
DATABASE_URL=

# Maximum number of online AI engine calls allowed per day before the system
# automatically switches every visitor to the built-in diagnostic engine.
# This protects free-tier AI quotas from being exhausted.
MAX_AI_REQUESTS_PER_DAY=50

# Standard Flask settings
FLASK_ENV=development
PORT=5000
